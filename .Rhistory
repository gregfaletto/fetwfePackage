x <- gsub(".*Tooltip |\\[.*?\\]", "", x)
x <- gsub("(\\w+)'s (\\d+)\\w+ congressional district", "\\1-\\2", x) # Nebraska-2 form
x <- gsub(" at-large congressional district", "-1", x)                 # Maine-1 form
trimws(x)
}
dt[, state := norm_state(state)]
# Drop non-rows / totals / blanks
dt <- dt[!is.na(D) & !is.na(R) & nzchar(state)]
dt <- dt[!grepl("Total|United States|Totals", state, ignore.case = TRUE)]
# Margins
dt[, `:=`(
year = y,
two_party = D + R,
dem_margin_pp = 100 * (D - R) / pmax(1, D + R)
)]
# National two-party margin
nat <- dt[, .(D = sum(D, na.rm = TRUE), R = sum(R, na.rm = TRUE))]
nat_margin_pp <- 100 * (nat$D - nat$R) / (nat$D + nat$R)
dt[, nat_dem_margin_pp := nat_margin_pp]
# simple passthrough
dt[, state_po := state]
dt[, .(year, state, state_po, D, R, two_party, dem_margin_pp, nat_dem_margin_pp)]
}
all <- rbindlist(lapply(years, parse_year), use.names = TRUE, fill = TRUE)
library(rvest)
library(data.table)
years <- 2008:2024
norm_state <- function(x){
x <- gsub(".*Tooltip |\\[.*?\\]", "", x)
x <- gsub("(\\w+)'s (\\d+)\\w+ congressional district", "\\1-\\2", x) # Nebraska-2 form
x <- gsub(" at-large congressional district", "-1", x)                 # Maine-1 form
trimws(x)
}
parse_year <- function(y){
url <- sprintf("https://en.wikipedia.org/wiki/%d_United_States_presidential_election", y)
pg  <- read_html(url)
# Get all wikitables and convert to data.frames
raw_tabs <- html_elements(pg, "table.wikitable")
if (length(raw_tabs) == 0) stop("No wikitable found for ", y)
# Helpers
numify <- function(x){
x <- gsub("\u2014|—|–", "", x)      # remove em/en dashes
x <- gsub("\\s", "", x)             # remove stray spaces
x <- gsub("[^0-9-]", "", x)         # keep digits and minus
x <- ifelse(nzchar(x), x, NA_character_)
as.numeric(x)
}
has_state_col <- function(nms){
any(grepl("^(state|state or district|jurisdiction)$", tolower(gsub("\\s+"," ", nms))))
}
looks_numericish <- function(col){
x <- numify(col)
sum(!is.na(x)) >= 30                # ≥ ~30 rows parse as numbers
}
# Score tables and pick the best candidate
scored <- list()
for (i in seq_along(raw_tabs)) {
tb <- try(html_table(raw_tabs[[i]], fill = TRUE), silent = TRUE)
if (inherits(tb, "try-error")) next
nms <- names(tb)
score <- 0
score <- score + has_state_col(nms)
score <- score + (NROW(tb) >= 45)
score <- score + (sum(sapply(tb, looks_numericish)) >= 2)
scored[[length(scored) + 1]] <- list(score = score, tb = as.data.table(tb))
}
if (!length(scored)) stop("Couldn't parse any wikitable for ", y)
pick <- scored[[ which.max(vapply(scored, `[[`, numeric(1), "score")) ]]$tb
# Standardize state col
st_col <- which.max(grepl("state|state or district|jurisdiction", tolower(names(pick))))
setnames(pick, st_col, "state")
# Header helpers
nms0 <- names(pick)
nms  <- tolower(gsub("\\s+", " ", nms0))
is_percenty <- function(v){
v <- tolower(v)
grepl("%|percent|share|pv\\.|pv|swing|margin", v)
}
looks_votes <- function(v){
v <- tolower(v)
grepl("vote|votes|popular", v) & !is_percenty(v)
}
vote_header_ok <- function(v){
v <- tolower(v)
looks_votes(v) | (!is_percenty(v) & !grepl("electoral|ev|rank|code|abbr|party", v))
}
# Party columns if present
dem_cols <- which(grepl("democratic", nms) & vote_header_ok(nms))
rep_cols <- which(grepl("republican", nms) & vote_header_ok(nms))
# Candidate-name headers as backup (more expansive lists, handle slashes/daggers)
cand_map <- list(
`2008` = list(D = c("barack", "obama", "biden"),    R = c("john", "mccain", "palin")),
`2012` = list(D = c("obama", "biden"),              R = c("romney", "ryan")),
`2016` = list(D = c("clinton", "hillary", "kaine"), R = c("trump", "donald", "pence")),
`2020` = list(D = c("biden", "joe", "harris"),      R = c("trump", "donald", "pence")),
`2024` = list(D = c("harris","kamala","walz","tim"),
R = c("trump","donald","vance","jd","jd vance","ven"))
)
if (length(dem_cols) == 0 || length(rep_cols) == 0) {
if (as.character(y) %in% names(cand_map)) {
dem_pat <- paste0(cand_map[[as.character(y)]]$D, collapse="|")
rep_pat <- paste0(cand_map[[as.character(y)]]$R, collapse="|")
dem_cols <- unique(c(dem_cols, which(grepl(dem_pat, nms) & vote_header_ok(nms))))
rep_cols <- unique(c(rep_cols, which(grepl(rep_pat, nms) & vote_header_ok(nms))))
}
}
# Choose the "votes, not percent" subcolumn if duplicated headers exist
prefer_votes_col <- function(idxs){
if (!length(idxs)) return(integer())
if (length(idxs) == 1) return(idxs)
# if any header mentions votes/popular, keep those
looks <- which(looks_votes(nms[idxs]))
if (length(looks)) return(idxs[looks])
idxs
}
dem_cols <- prefer_votes_col(dem_cols)
rep_cols <- prefer_votes_col(rep_cols)
pick_numeric_col <- function(dt, idxs){
if (!length(idxs)) return(NA_integer_)
sums <- sapply(idxs, function(j) sum(numify(dt[[j]]), na.rm = TRUE))
idxs[which.max(sums)]
}
jD <- pick_numeric_col(pick, dem_cols)
jR <- pick_numeric_col(pick, rep_cols)
# Final fallback: pick two biggest numeric-ish columns overall (not percents if we can tell)
if (is.na(jD) || is.na(jR)) {
cand_idx <- which(sapply(pick, looks_numericish))
# try to drop obvious percent columns by name
cand_idx <- cand_idx[!is_percenty(nms0[cand_idx])]
if (length(cand_idx) < 2) {
# if still too few, allow percents but we'll rely on totals magnitude
cand_idx <- which(sapply(pick, looks_numericish))
}
if (length(cand_idx) >= 2) {
sums <- sapply(cand_idx, function(j) sum(numify(pick[[j]]), na.rm = TRUE))
top2 <- cand_idx[order(sums, decreasing = TRUE)][1:2]
tmp <- copy(pick)
tmp[, state_clean := gsub("\\s+", " ", trimws(state))]
tmp[, v1 := numify(tmp[[ top2[1] ]])]
tmp[, v2 := numify(tmp[[ top2[2] ]])]
guess <- tmp[grepl("District of Columbia|DC|Hawaii|HI", state_clean) & !is.na(v1) & !is.na(v2)][1]
if (nrow(guess)) {
if (guess$v1 > guess$v2) { jD <- top2[1]; jR <- top2[2] } else { jD <- top2[2]; jR <- top2[1] }
} else { jD <- top2[1]; jR <- top2[2] }
} else {
stop("Couldn't detect vote columns for ", y)
}
}
# Build cleaned DT
dt <- copy(pick)
dt[, D := numify(dt[[jD]])]
dt[, R := numify(dt[[jR]])]
# Normalize state (keep your district normalization)
norm_state <- function(x){
x <- gsub(".*Tooltip |\\[.*?\\]", "", x)
x <- gsub("(\\w+)'s (\\d+)\\w+ congressional district", "\\1-\\2", x) # Nebraska-2 form
x <- gsub(" at-large congressional district", "-1", x)                 # Maine-1 form
trimws(x)
}
dt[, state := norm_state(state)]
# Drop non-rows / totals / blanks
dt <- dt[!is.na(D) & !is.na(R) & nzchar(state)]
dt <- dt[!grepl("Total|United States|Totals", state, ignore.case = TRUE)]
# Margins
dt[, `:=`(
year = y,
two_party = D + R,
dem_margin_pp = 100 * (D - R) / pmax(1, D + R)
)]
# National two-party margin
nat <- dt[, .(D = sum(D, na.rm = TRUE), R = sum(R, na.rm = TRUE))]
nat_margin_pp <- 100 * (nat$D - nat$R) / (nat$D + nat$R)
dt[, nat_dem_margin_pp := nat_margin_pp]
# simple passthrough
dt[, state_po := state]
dt[, .(year, state, state_po, D, R, two_party, dem_margin_pp, nat_dem_margin_pp)]
}
all <- rbindlist(lapply(years, parse_year), use.names = TRUE, fill = TRUE)
