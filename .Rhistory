# Robust fetch with retries + polite delay + UA
fetch_html <- function(url, tries = 5, base_sleep = 0.8) {
ua <- user_agent("Academic script via R/rvest (mailto:you@example.com)")
for (i in seq_len(tries)) {
# small jittered backoff
if (i > 1) Sys.sleep(base_sleep * runif(1, 0.8, 1.2) * (2^(i-2)))
resp <- try(GET(url, ua, timeout(30)), silent = TRUE)
if (!inherits(resp, "try-error") && identical(status_code(resp), 200L)) {
raw <- content(resp, as = "raw")
return(read_html(raw))
}
}
stop("Failed to fetch after ", tries, " tries: ", url)
}
